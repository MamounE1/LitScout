# Use the Supabase "Session/Transaction pooler" connection string (IPv4-friendly),
# not the direct db.<ref>.supabase.co host (IPv6-only).
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
JWT_SECRET_KEY=changeme-generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://litscout.netlify.app
